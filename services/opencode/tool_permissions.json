{
  "$schema": "Tool permission definitions inspired by Claude Code leaked architecture (March 2026)",
  "version": "1.0.0",
  "description": "Clasificación de riesgo y reglas de auto-aprobación por herramienta",
  "tools": {
    "read_file": {
      "risk": "low",
      "auto_approve": true,
      "description": "Leer contenido de archivos",
      "max_size_bytes": 1048576,
      "blocked_extensions": [".exe", ".dll", ".bin", ".iso"]
    },
    "grep": {
      "risk": "low",
      "auto_approve": true,
      "description": "Buscar patrones en archivos",
      "max_results": 100
    },
    "glob": {
      "risk": "low",
      "auto_approve": true,
      "description": "Buscar archivos por nombre/patrón"
    },
    "list_dir": {
      "risk": "low",
      "auto_approve": true,
      "description": "Listar contenido de directorios",
      "max_depth": 3
    },
    "edit_file": {
      "risk": "medium",
      "auto_approve": false,
      "description": "Modificar archivos existentes",
      "require_diff_preview": true,
      "backup_before_edit": true
    },
    "write_file": {
      "risk": "medium",
      "auto_approve": false,
      "description": "Crear archivos nuevos",
      "blocked_paths": ["/etc/", "/usr/", "/bin/", "C:\\Windows\\"]
    },
    "bash": {
      "risk": "high",
      "auto_approve": false,
      "description": "Ejecutar comandos de shell",
      "require_explanation": true,
      "blocked_patterns": [
        "rm -rf",
        "rm -r /",
        "sudo rm",
        "format",
        "mkfs",
        "> /dev/",
        "chmod 777",
        "curl.*| bash",
        "wget.*| sh",
        "dd if=",
        ":(){:|:&};:",
        "shutdown",
        "reboot"
      ],
      "max_execution_seconds": 120
    },
    "git_commit": {
      "risk": "medium",
      "auto_approve": false,
      "description": "Crear commits de Git",
      "require_message": true
    },
    "git_push": {
      "risk": "critical",
      "auto_approve": false,
      "description": "Push a repositorio remoto",
      "require_diff_review": true,
      "require_branch_check": true,
      "blocked_flags": ["--force", "-f"]
    },
    "git_reset": {
      "risk": "critical",
      "auto_approve": false,
      "description": "Reset de historial Git",
      "require_stash_first": true
    },
    "pip_install": {
      "risk": "high",
      "auto_approve": false,
      "description": "Instalar paquetes Python",
      "require_explanation": true,
      "prefer_virtual_env": true
    },
    "npm_install": {
      "risk": "high",
      "auto_approve": false,
      "description": "Instalar paquetes Node.js",
      "require_explanation": true
    }
  },
  "blast_radius_assessment": {
    "enabled": true,
    "description": "Antes de ejecutar acciones de riesgo medio o superior, el agente debe evaluar el impacto potencial",
    "criteria": [
      "¿Es reversible? (git stash, backup, undo)",
      "¿Afecta solo archivos del proyecto o archivos del sistema?",
      "¿Requiere reinicio de servicios?",
      "¿Puede corromper datos persistentes (DB, configs)?"
    ]
  }
}
